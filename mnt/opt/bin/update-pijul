#!/bin/bash
# update-pijul — Install or update Pijul version control system
#
# Builds from source using cargo and symlinks the binary into /opt/bin.
# Pijul's own identity (author name/email) is configured per-user via
# ~/.config/pijul/config.toml — see /etc/skel for the seeded default.
#
# pijul: /opt/pijul/target/release/pijul  → /opt/bin/pijul
#
# Prerequisites: rust (cargo), git, pkg-config, openssl, libsodium, zstd

PIJUL_DIR=/opt/pijul
BIN_DIR=/opt/bin

if [ "$(id -u)" -ne 0 ]; then
    echo "ERROR: update-pijul must be run as root (use sudo)."
    exit 1
fi

# ─────────────────────────────────────────
#  Preflight checks
# ─────────────────────────────────────────

for cmd in cargo git pkg-config; do
    if ! command -v "$cmd" &>/dev/null; then
        echo "ERROR: '$cmd' is not installed. Install it and re-run."
        exit 1
    fi
done

mkdir -p "$BIN_DIR"

# ─────────────────────────────────────────
#  Source
# ─────────────────────────────────────────

echo "=== Pijul ==="

if [ -d "$PIJUL_DIR/.git" ]; then
    echo "  Updating existing clone..."
    git -C "$PIJUL_DIR" pull --ff-only
else
    echo "  Cloning Pijul..."
    git clone https://github.com/pijul-scm/pijul "$PIJUL_DIR"
fi

# ─────────────────────────────────────────
#  Build
# ─────────────────────────────────────────

echo "  Building (cargo build --release)..."
cargo build --release --locked --manifest-path "$PIJUL_DIR/Cargo.toml"

BUILT_BIN="$PIJUL_DIR/target/release/pijul"

if [ ! -f "$BUILT_BIN" ]; then
    echo "ERROR: Build failed — $BUILT_BIN not found."
    exit 1
fi

ln -sf "$BUILT_BIN" "$BIN_DIR/pijul"
echo "  Symlinked: $BIN_DIR/pijul → $BUILT_BIN"

# ─────────────────────────────────────────
#  Done
# ─────────────────────────────────────────

echo ""
echo "=== Done ==="
echo "  pijul: $(which pijul) — $(pijul --version)"
echo ""
echo "  User identity is read from ~/.config/pijul/config.toml"
echo "  The skel default is seeded at /etc/skel/.config/pijul/config.toml"
echo ""
echo "  Run 'sudo update-pijul' at any time to update."
