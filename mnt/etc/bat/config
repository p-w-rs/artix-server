# /etc/bat/config — system-wide bat configuration
# bat reads this file on every invocation (alongside per-user ~/.config/bat/config).
# Reference: bat --help

# Use the custom Selenized Dark truecolor theme.
# If you prefer to inherit colors purely from the terminal palette instead,
# switch to "base16" and make sure your terminal is set to Selenized Dark.
--theme="Selenized Dark"

# Show line numbers, git change markers, and the filename header.
--style="numbers,changes,header"

# Always request color output (safe — bat detects TTY and disables when piped).
--color=always

# Italic text for comments and doc-strings (requires terminal support).
--italic-text=always

# Use a sensible pager. -R passes ANSI colors through; -F quits if output fits
# on one screen; -X avoids clearing the screen on exit.
--pager="less -RFX"
